# =============================================================================
# AulaCAL Backend — Variables de Entorno
# =============================================================================
# INSTRUCCIONES:
#   1. Copiá este archivo: cp .env.example .env
#   2. Completá cada valor en .env con tus credenciales reales.
#   3. NUNCA subas .env al repositorio (ya está en .gitignore).
# =============================================================================


# -----------------------------------------------------------------------------
# ENTORNO DE EJECUCIÓN
# -----------------------------------------------------------------------------

# Entorno actual. Valores válidos: development | staging | production
APP_ENV=development

# Nombre visible de la aplicación (usado en emails, logs, etc.)
APP_NAME=AulaCAL

# Versión de la API (se muestra en /docs y en headers de respuesta)
APP_VERSION=1.0.0

# URL base del backend (sin barra final)
# En desarrollo: http://localhost:8000
# En producción: https://api.aulacal.com
APP_BASE_URL=http://localhost:8000

# URL base del frontend (se usa en emails y configuración de CORS)
FRONTEND_URL=http://localhost:3000


# -----------------------------------------------------------------------------
# SEGURIDAD — JWT
# -----------------------------------------------------------------------------

# Clave secreta para firmar los JWT.
# Generá una con: openssl rand -hex 32
# CRÍTICO: debe ser larga, aleatoria y ÚNICA por entorno.
JWT_SECRET_KEY=REEMPLAZAR_CON_CLAVE_SEGURA

# Algoritmo de firma del JWT. No cambiar salvo necesidad específica.
JWT_ALGORITHM=HS256

# Tiempo de vida del Access Token en minutos.
# Recomendado: 15 minutos (balance entre seguridad y UX).
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15

# Tiempo de vida del Refresh Token en días.
# Recomendado: 7 días.
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Cada cuántos días se le pide al usuario el código de doble factor por email.
TWO_FACTOR_CODE_EXPIRE_DAYS=30

# Tiempo de vida de los códigos de verificación de email / 2FA en minutos.
# Aplica a: registro, 2FA y reset de contraseña.
EMAIL_CODE_EXPIRE_MINUTES=15


# -----------------------------------------------------------------------------
# BASE DE DATOS — SUPABASE
# -----------------------------------------------------------------------------

# URL de conexión directa a PostgreSQL de Supabase.
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Se encuentra en: Supabase Dashboard → Project Settings → Database → Connection string
SUPABASE_DB_URL=postgresql://postgres:PASSWORD@db.XXXX.supabase.co:5432/postgres

# URL pública del proyecto Supabase (para usar el cliente oficial de Supabase)
# Se encuentra en: Supabase Dashboard → Project Settings → API → Project URL
SUPABASE_URL=https://XXXX.supabase.co

# Clave anónima pública de Supabase (safe para incluir en frontend también)
# Se encuentra en: Supabase Dashboard → Project Settings → API → anon public
SUPABASE_ANON_KEY=REEMPLAZAR

# Clave de servicio de Supabase (privilegios totales — SOLO usar en backend)
# Se encuentra en: Supabase Dashboard → Project Settings → API → service_role
# CRÍTICO: nunca exponer esta clave en el frontend ni en logs.
SUPABASE_SERVICE_ROLE_KEY=REEMPLAZAR


# -----------------------------------------------------------------------------
# EMAIL — SMTP
# -----------------------------------------------------------------------------

# Proveedor SMTP para envío de emails transaccionales.
# En desarrollo podés usar Mailtrap (https://mailtrap.io) para no enviar emails reales.
# En producción: SendGrid, AWS SES, Resend, etc.

SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587

# Usuario y contraseña del servidor SMTP.
SMTP_USER=REEMPLAZAR
SMTP_PASSWORD=REEMPLAZAR

# Nombre y email que verá el destinatario como remitente.
EMAIL_FROM_NAME=AulaCAL
EMAIL_FROM_ADDRESS=noreply@aulacal.com

# Usar TLS para la conexión SMTP (recomendado: True en producción).
SMTP_USE_TLS=True


# -----------------------------------------------------------------------------
# CLOUDFLARE STREAM — Videos
# -----------------------------------------------------------------------------

# Account ID de Cloudflare.
# Se encuentra en: Cloudflare Dashboard → lado derecho de la página principal.
CLOUDFLARE_ACCOUNT_ID=REEMPLAZAR

# API Token de Cloudflare con permisos de Stream.
# Crear en: Cloudflare Dashboard → My Profile → API Tokens → Create Token
# Permisos necesarios: Stream:Edit
CLOUDFLARE_API_TOKEN=REEMPLAZAR

# Clave para firmar URLs de video privadas (Signed URLs).
# Se genera en: Cloudflare Stream Dashboard → Keys → Create Key
# CRÍTICO: mantener en secreto. Cualquiera con esta clave puede generar URLs válidas.
CLOUDFLARE_STREAM_SIGNING_KEY=REEMPLAZAR

# Tiempo de vida de los tokens de streaming firmados en segundos.
# 3600 = 1 hora. El video deja de ser accesible al expirar el token.
CLOUDFLARE_STREAM_TOKEN_EXPIRE_SECONDS=3600


# -----------------------------------------------------------------------------
# MERCADOPAGO
# -----------------------------------------------------------------------------

# Access Token de MercadoPago (identifica tu cuenta y entorno).
# TEST: empieza con "TEST-"  → para desarrollo y pruebas.
# PROD: empieza con "APP_USR-" → para producción real.
# Se obtiene en: https://www.mercadopago.com.ar/developers/panel/app
MERCADOPAGO_ACCESS_TOKEN=TEST-REEMPLAZAR

# Public Key de MercadoPago (se usa también en el frontend para el Brick de pago).
MERCADOPAGO_PUBLIC_KEY=TEST-REEMPLAZAR

# URL donde MercadoPago enviará las notificaciones de pago (webhook).
# Debe ser una URL pública accesible desde internet.
# En desarrollo, usá ngrok: https://TU_ID.ngrok.io/api/v1/payments/mercadopago/webhook
MERCADOPAGO_WEBHOOK_URL=https://TU_DOMINIO/api/v1/payments/mercadopago/webhook

# Secret para validar la firma de los webhooks de MercadoPago.
# Se configura en: MercadoPago Dashboard → Tus aplicaciones → Webhooks
MERCADOPAGO_WEBHOOK_SECRET=REEMPLAZAR


# -----------------------------------------------------------------------------
# PAYPAL
# -----------------------------------------------------------------------------

# Entorno de PayPal. Valores válidos: sandbox | live
# sandbox → para pruebas (no mueve dinero real)
# live    → para producción
PAYPAL_ENV=sandbox

# Client ID y Secret de la app de PayPal.
# Se obtienen en: https://developer.paypal.com/dashboard/applications
PAYPAL_CLIENT_ID=REEMPLAZAR
PAYPAL_CLIENT_SECRET=REEMPLAZAR

# URL donde PayPal enviará las notificaciones (webhook).
PAYPAL_WEBHOOK_URL=https://TU_DOMINIO/api/v1/payments/paypal/webhook

# ID del webhook registrado en PayPal (necesario para validar la firma).
# Se obtiene al registrar el webhook en el dashboard de PayPal.
PAYPAL_WEBHOOK_ID=REEMPLAZAR


# -----------------------------------------------------------------------------
# RATE LIMITING
# -----------------------------------------------------------------------------

# Máximo de requests permitidos por IP en la ventana de tiempo definida.
# Aplica especialmente a los endpoints de autenticación.
RATE_LIMIT_MAX_REQUESTS=10

# Ventana de tiempo en segundos para el rate limiting.
# 60 = máximo RATE_LIMIT_MAX_REQUESTS por minuto por IP.
RATE_LIMIT_WINDOW_SECONDS=60


# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------

# Orígenes permitidos para hacer requests al backend, separados por coma.
# En desarrollo: http://localhost:3000
# En producción: https://aulacal.com,https://www.aulacal.com
CORS_ALLOWED_ORIGINS=http://localhost:3000
